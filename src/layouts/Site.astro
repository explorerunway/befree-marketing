---
// Site.astro — shared shell for every marketing page.
// Head (fonts, meta, OG) + fixed paper-grain overlay + Nav + Footer.
// Values are verbatim from the design handoff specs (designs/*.dc.html).
import '../styles/tokens.css';
import '@phosphor-icons/web/bold';
import '@phosphor-icons/web/fill';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  active: 'home' | 'mac' | 'pricing' | 'android';
}
const { title, description, active } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FBF6EC" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://heybefree.app/mascot.png" />
    <meta property="og:image:alt" content="BeFree's kawaii mic mascot" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://heybefree.app/mascot.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..700&family=Geist:wght@400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page">
      <div class="grain" aria-hidden="true"></div>
      <div class="content">
        <Nav active={active} />
        <slot />
        <Footer />
      </div>
    </div>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  @keyframes bfBreathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.04);
    }
  }
  @keyframes bfPulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(2.3);
      opacity: 0;
    }
  }
  @media (max-width: 620px) {
    .bf-hide-sm {
      display: none !important;
    }
    .bf-split {
      grid-template-columns: 1fr !important;
    }
  }
  /* Respect reduced-motion: stop the infinite mascot/pulse loops entirely. */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<style>
  .page {
    position: relative;
    overflow-x: hidden;
  }
  .grain {
    /* absolute (scrolls with the page), NOT fixed. A fixed full-viewport
       mix-blend-mode layer forces the browser to re-blend the whole screen on
       every scroll frame — the main source of scroll jank. Letting it scroll
       with the content lets the compositor cache the blended layer. Visually
       identical for a fine noise texture. */
    position: absolute;
    inset: 0;
    background-image: url('/assets/paper-grain.png');
    background-size: 256px 256px;
    mix-blend-mode: multiply;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }
  .content {
    position: relative;
    z-index: 1;
  }
</style>
