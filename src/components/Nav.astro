---
// Sticky blurred nav — spec: designs/BeFree*.dc.html "NAV" section.
// Active page gets weight 600 + accent (and ph-fill for the Mac glyph).
interface Props {
  active: 'home' | 'mac' | 'pricing';
}
const { active } = Astro.props;
const ctaHref = active === 'pricing' ? '#tiers' : '#download';
const ctaLabel = active === 'pricing' ? 'Get started' : 'Download';
---

<div class="navbar">
  <div class="inner">
    <a href="/" class="logo">
      <img src="/assets/icon.png" alt="BeFree" width="34" height="34" />
      <span>BeFree</span>
    </a>
    <div class="links bf-navlinks">
      <a href="/#features" class="link bf-hide-sm">Features</a>
      <a href="/mac" class:list={['link', 'mac', { active: active === 'mac' }]}>
        <i class={active === 'mac' ? 'ph-fill ph-desktop' : 'ph-bold ph-desktop'}></i> Mac
      </a>
      <a href="/pricing" class:list={['link', { active: active === 'pricing' }]}>Pricing</a>
      <a href={ctaHref} class="cta">{ctaLabel}</a>
    </div>
  </div>
</div>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 13px clamp(18px, 4vw, 40px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
  }
  .logo img {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    box-shadow: var(--elev-1);
    display: block;
  }
  .logo span {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.3px;
    color: var(--text);
  }
  .links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  @media (max-width: 620px) {
    .links {
      gap: 16px;
    }
  }
  .link {
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .link:hover {
    color: var(--text);
  }
  .link.mac {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .link.mac i {
    font-size: 15px;
  }
  .link.active {
    font-weight: 600;
    color: var(--accent);
  }
  .cta {
    text-decoration: none;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.2px;
    padding: 10px 18px;
    border-radius: var(--radius-input);
    box-shadow: var(--elev-1);
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .cta:hover {
    transform: translateY(-1px);
    box-shadow: var(--elev-2);
  }
</style>
