---
// Black App Store / Mac App Store badge — spec: "DOWNLOAD CTA" sections.
// Real listing URL (the spec's /app/befree placeholder swapped for the live id).
interface Props {
  store: 'ios' | 'mac';
  href?: string;
}
const { store, href = 'https://apps.apple.com/app/id6763826891' } = Astro.props;
const line2 = store === 'mac' ? 'Mac App Store' : 'App Store';
---

<a href={href} class="badge">
  <svg viewBox="0 0 384 512" aria-hidden="true">
    <path
      d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C61.5 141.2 0 184.4 0 272.1c0 25.9 4.7 52.7 14.2 80.3 12.6 36.4 58 125.6 105.4 124.1 24.8-.6 42.3-17.6 74.6-17.6 31.3 0 47.5 17.6 76.4 17.6 47.8-.7 88.9-81.7 100.9-118.2-64.1-30.2-63.2-88.5-63.2-90.1zm-49.4-152.9c23.9-28.3 21.7-54.1 21-63.4-21.1 1.2-45.5 14.3-59.4 30.4-15.3 17.3-24.3 38.7-22.4 63.1 22.8 1.7 43.6-10 60.8-30.1z"
    ></path>
  </svg>
  <span class="text">
    <span class="small">Download on the</span>
    <span class="big">{line2}</span>
  </span>
</a>

<style>
  .badge {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 13px;
    background: #000;
    border: 1px solid #a6a6a6;
    padding: 13px 24px;
    border-radius: 14px;
  }
  .badge:hover {
    border-color: #f2ead6;
  }
  svg {
    width: 34px;
    height: 34px;
    fill: #fff;
    flex: none;
    display: block;
  }
  .text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
    white-space: nowrap;
  }
  .small {
    font-family: var(--font-body);
    font-size: 11px;
    color: #fff;
    margin-bottom: 3px;
  }
  .big {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 600;
    color: #fff;
  }
</style>
