---
// Dark walnut download CTA — spec: "DOWNLOAD CTA" on all three pages.
// Badges/buttons come in via the default slot so each page composes its own row.
interface Props {
  id?: string;
  title: string;
  sub: string;
  meta?: string;
  mascotSize?: number;
  padTop?: boolean; // pricing omits the top padding
}
const { id = 'download', title, sub, meta, mascotSize = 88, padTop = true } = Astro.props;
---

<section id={id} class:list={['wrap', { 'no-top': !padTop }]}>
  <div class="panel">
    <div class="grain" aria-hidden="true"></div>
    <div class="inner">
      <div class="mascot" style={`width:${mascotSize}px; height:${mascotSize}px;`}>
        <img src="/assets/cutemic.png" alt="" />
      </div>
      <h2>{title}</h2>
      <p>{sub}</p>
      <div class="row">
        <slot />
      </div>
      {meta && <div class="meta">{meta}</div>}
    </div>
  </div>
</section>

<style>
  .wrap {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(40px, 6vh, 80px) clamp(18px, 4vw, 40px);
  }
  .wrap.no-top {
    padding-top: 0;
    padding-bottom: clamp(44px, 7vh, 84px);
  }
  .panel {
    background: var(--bg-inverse);
    border-radius: var(--radius-sheet);
    padding: clamp(36px, 6vw, 72px) clamp(24px, 4vw, 48px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .grain {
    position: absolute;
    inset: 0;
    background-image: url('/assets/paper-grain.png');
    background-size: 256px 256px;
    mix-blend-mode: overlay;
    opacity: 0.18;
    pointer-events: none;
  }
  .inner {
    position: relative;
  }
  .mascot {
    margin: 0 auto 22px;
    animation: bfBreathe 4200ms cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }
  .mascot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 5vw, 52px);
    line-height: 1.02;
    letter-spacing: -1.2px;
    color: #f2ead6;
    margin: 0;
    text-wrap: balance;
  }
  p {
    font-family: var(--font-body);
    font-size: clamp(16px, 2vw, 19px);
    color: #c4b89d;
    margin: 14px auto 30px;
    max-width: 440px;
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #7e725f;
    margin-top: 20px;
  }
</style>
