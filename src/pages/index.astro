---
// Home — spec: designs/BeFree.dc.html.
import Site from '../layouts/Site.astro';
import BrainDumpDemo from '../components/BrainDumpDemo.astro';
import AppWindow from '../components/AppWindow.astro';
import StoreBadge from '../components/StoreBadge.astro';
import DownloadCTA from '../components/DownloadCTA.astro';

const features = [
  {
    icon: 'check-square',
    tool: 'var(--tool-task)',
    tint: 12,
    title: "Tasks that don't nag",
    body: "To-dos land with the right priority, quietly waiting until you're ready. No red badges screaming for attention.",
  },
  {
    icon: 'bell',
    tool: 'var(--tool-reminder)',
    tint: 12,
    title: 'Reminders, on time',
    body: 'Say "remind me to call mum tonight" and BeFree nudges you at the right moment — recurring ones included.',
  },
  {
    icon: 'calendar-dots',
    tool: 'var(--tool-event)',
    tint: 12,
    title: 'Events from a sentence',
    body: '"Lunch with Sam Friday at 1" becomes a real calendar event. BeFree resolves the day and time for you.',
  },
  {
    icon: 'list-checks',
    tool: 'var(--tool-grocery)',
    tint: 14,
    title: 'Lists that fill themselves',
    body: '"We\'re out of coffee and oat milk" drops both onto your groceries. Named lists, no tapping through menus.',
  },
  {
    icon: 'note',
    tool: 'var(--tool-note)',
    tint: 12,
    title: 'Notes, kept whole',
    body: "Half-formed thoughts and ideas stay intact — captured as notes, not forced into a checkbox they don't fit.",
  },
];

const windowCards = [
  { title: 'Design review', meta: '2:00 PM', icon: 'calendar-dots', tool: 'var(--tool-event)', checkable: false },
  { title: 'Call mum', meta: 'Tonight', icon: 'bell', tool: 'var(--tool-reminder)' },
  { title: 'Finish Q3 report', meta: 'Today · 5 PM', icon: 'check', tool: 'var(--tool-task)', priority: 'high' as const },
  { title: 'Coffee, oat milk', meta: 'Groceries', icon: 'basket', tool: 'var(--tool-grocery)' },
];

---

<Site
  title="BeFree — Put it all down. Walk out lighter."
  description="BeFree is the voice-first app that turns a messy brain dump into tasks, reminders, calendar events, lists, and notes. You just talk — it sorts the rest."
  active="home"
>
  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="mascot">
      <img src="/assets/cutemic.png" alt="BeFree mascot" />
    </div>
    <div class="eyebrow">Now on iPhone — Mac on the way</div>
    <h1>Put it all down.<br /><span class="voice">Walk out lighter.</span></h1>
    <p>
      BeFree is the voice-first app that turns a messy brain dump into tasks, reminders, calendar
      events, lists, and notes. You just talk — it sorts the rest.
    </p>
  </section>

  <!-- ══════════ LIVE DEMO ══════════ -->
  <section id="try" class="demo-section">
    <div class="demo-title">
      Try it now — say the messy thing. <span class="live-badge">live</span>
    </div>
    <div class="demo-stage">
      <BrainDumpDemo />
    </div>
    <div class="trust-row">
      <span>Free on the App Store</span>
      <span class="sep"></span>
      <span>No account needed</span>
      <span class="sep"></span>
      <span>Private by default</span>
    </div>
  </section>

  <!-- ══════════ HOW IT WORKS ══════════ -->
  <section class="how">
    <div class="section-head">
      <div class="eyebrow">How it works</div>
      <h2>Three seconds of talking.<br />A whole day, sorted.</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-medal" style="background: color-mix(in srgb, var(--tool-capture) 12%, transparent);">
          <i class="ph-bold ph-microphone" style="color: var(--tool-capture);"></i>
        </div>
        <div class="step-num">01</div>
        <h3>Speak your mind</h3>
        <p>Open BeFree and just talk. The dentist, the coffee you're out of, that idea — all in one breath.</p>
      </div>
      <div class="step">
        <div class="step-medal" style="background: color-mix(in srgb, var(--accent) 12%, transparent);">
          <i class="ph-fill ph-sparkle" style="color: var(--accent);"></i>
        </div>
        <div class="step-num">02</div>
        <h3>It sorts itself</h3>
        <p>BeFree reads the mess and files each piece where it belongs — the right list, the right day, the right nudge.</p>
      </div>
      <div class="step">
        <div class="step-medal" style="background: color-mix(in srgb, var(--tool-grocery) 14%, transparent);">
          <i class="ph-bold ph-check-circle" style="color: var(--tool-grocery);"></i>
        </div>
        <div class="step-num">03</div>
        <h3>Walk out lighter</h3>
        <p>Your day's laid out and nothing's rattling around your head. That's the whole point.</p>
      </div>
    </div>
  </section>

  <!-- ══════════ FEATURES ══════════ -->
  <section id="features" class="features">
    <div class="section-head">
      <div class="eyebrow">One dump, five kinds of order</div>
      <h2>Everything your head is holding —<br />each in its right place.</h2>
    </div>
    <div class="grid">
      {
        features.map((f) => (
          <div class="feature">
            <div
              class="feature-medal"
              style={`background: color-mix(in srgb, ${f.tool} ${f.tint}%, transparent);`}
            >
              <i class={`ph-bold ph-${f.icon}`} style={`color: ${f.tool};`} />
            </div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))
      }
      <div class="feature dark">
        <div class="grain-overlay" aria-hidden="true"></div>
        <div class="dark-inner">
          <div class="feature-medal" style="background: color-mix(in srgb, var(--accent) 30%, transparent);">
            <i class="ph-fill ph-sparkle" style="color: #E6C7ED;"></i>
          </div>
          <h3>AI that speaks human</h3>
          <p>
            The magic underneath: BeFree understands how you actually talk — run-ons, "oh and,"
            relative dates — and files it all correctly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ MAC IN CONTEXT ══════════ -->
  <section class="mac-context">
    <div class="section-head">
      <div class="eyebrow">Coming soon — BeFree for Mac</div>
      <h2>Right where you already work.</h2>
      <p class="section-sub">
        A thought hits mid-email. Hit one hotkey, say it, and get back to work. That's BeFree for
        Mac — in development now, with menu-bar capture and instant iPhone sync built in.
      </p>
    </div>
    <div class="window-wrap">
      <AppWindow cards={windowCards} subtitle="Six things on the day." />
    </div>
    <div class="pills">
      <div class="pill"><i class="ph-bold ph-command" style="color: var(--accent);"></i> Global hotkey capture</div>
      <div class="pill"><i class="ph-bold ph-list" style="color: var(--brass);"></i> Menu-bar quick capture</div>
      <div class="pill"><i class="ph-bold ph-arrows-clockwise" style="color: var(--tool-event);"></i> Instant iPhone sync</div>
    </div>
    <div class="explore">
      <a href="/mac">Explore BeFree for Mac <i class="ph-bold ph-arrow-right"></i></a>
    </div>
  </section>

  <!-- ══════════ VOICE MOMENT ══════════ -->
  <section class="voice-moment">
    <i class="ph-fill ph-quotes"></i>
    <p>Say the messy thing. We'll make it a day.</p>
  </section>

  <!-- ══════════ PRICING TEASER ══════════ -->
  <section class="teaser">
    <div class="panel">
      <div class="copy">
        <div class="eyebrow">Pricing</div>
        <h2>Start free. Go Pro when life gets loud.</h2>
        <p>
          Everything's included free — capture, AI sorting, sync, widgets. Pro raises your monthly
          AI budget about 100× so heavy weeks never hit a wall.
        </p>
      </div>
      <div class="actions">
        <a href="#download" class="primary">Get BeFree free</a>
        <a href="/pricing" class="secondary">Compare plans →</a>
      </div>
    </div>
  </section>

  <!-- ══════════ DOWNLOAD CTA ══════════ -->
  <DownloadCTA
    title="Put your head down."
    sub="Free on iPhone. Your first brain dump is thirty seconds away."
    meta="Free · iPhone · Mac in development"
  >
    <StoreBadge store="ios" />
  </DownloadCTA>
</Site>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--brass-deep);
    margin-bottom: 16px;
  }

  /* hero */
  .hero {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(34px, 6vh, 74px) clamp(18px, 4vw, 40px) clamp(20px, 3vh, 34px);
    text-align: center;
  }
  .mascot {
    width: 104px;
    height: 104px;
    margin: 0 auto clamp(16px, 2.5vh, 24px);
    animation: bfBreathe 4200ms cubic-bezier(0.65, 0, 0.35, 1) infinite;
    filter: drop-shadow(0 16px 22px rgba(31, 26, 20, 0.18));
  }
  .mascot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(38px, 7vw, 72px);
    line-height: 1;
    letter-spacing: -2px;
    color: var(--text);
    margin: 0;
    text-wrap: balance;
  }
  .hero .voice {
    font-style: italic;
    font-weight: 600;
    color: var(--accent);
  }
  .hero p {
    font-family: var(--font-body);
    font-size: clamp(18px, 2.4vw, 22px);
    line-height: 1.5;
    color: var(--text-secondary);
    margin: clamp(16px, 2.5vh, 24px) auto 0;
    max-width: 600px;
    text-wrap: pretty;
  }

  /* demo */
  .demo-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px) clamp(16px, 3vh, 28px);
  }
  .demo-title {
    text-align: center;
    margin-bottom: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(19px, 2.6vw, 25px);
    color: var(--text);
  }
  .live-badge {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    vertical-align: middle;
    background: var(--accent-subtle);
    padding: 4px 9px;
    border-radius: var(--radius-badge);
  }
  .demo-stage {
    background: var(--accent-subtle);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sheet);
    padding: clamp(14px, 2.5vw, 24px);
    box-shadow: var(--elev-3);
  }
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted);
  }
  .sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  /* section heads */
  .section-head {
    text-align: center;
    margin-bottom: clamp(30px, 5vh, 54px);
  }
  .section-head .eyebrow {
    margin-bottom: 12px;
  }
  .section-head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 4.6vw, 46px);
    line-height: 1.05;
    letter-spacing: -1px;
    color: var(--text);
    margin: 0;
    text-wrap: balance;
  }
  .section-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 14px auto 0;
    max-width: 560px;
  }

  /* how it works */
  .how {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(50px, 8vh, 100px) clamp(18px, 4vw, 40px) clamp(30px, 4vh, 50px);
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 270px), 1fr));
    gap: 20px;
  }
  .step {
    text-align: center;
    padding: 8px;
  }
  .step-medal {
    width: 66px;
    height: 66px;
    margin: 0 auto 18px;
    border-radius: var(--radius-card);
    display: grid;
    place-items: center;
  }
  .step-medal i {
    font-size: 32px;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .step h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 23px;
    letter-spacing: -0.3px;
    color: var(--text);
    margin: 0 0 8px;
  }
  .step p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 auto;
    max-width: 300px;
  }

  /* features */
  .features {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(40px, 6vh, 80px) clamp(18px, 4vw, 40px);
  }
  .features .section-head {
    margin-bottom: clamp(28px, 4vh, 48px);
  }
  .features .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 18px;
  }
  .feature {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    box-shadow: var(--elev-1);
    padding: 26px 26px 24px;
  }
  .feature-medal {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-input);
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }
  .feature-medal i {
    font-size: 26px;
  }
  .feature h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 21px;
    letter-spacing: -0.3px;
    color: var(--text);
    margin: 0 0 7px;
  }
  .feature p {
    font-family: var(--font-body);
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }
  .feature.dark {
    background: var(--bg-inverse);
    box-shadow: var(--elev-2);
    position: relative;
    overflow: hidden;
  }
  .grain-overlay {
    position: absolute;
    inset: 0;
    background-image: url('/assets/paper-grain.png');
    background-size: 256px 256px;
    mix-blend-mode: overlay;
    opacity: 0.18;
    pointer-events: none;
  }
  .dark-inner {
    position: relative;
  }
  .feature.dark h3 {
    color: #f2ead6;
  }
  .feature.dark p {
    color: #c4b89d;
  }

  /* mac in context */
  .mac-context {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(44px, 7vh, 90px) clamp(18px, 4vw, 40px);
  }
  .mac-context .section-head {
    margin-bottom: clamp(28px, 4vh, 46px);
  }
  .mac-context .section-head h2 {
    margin-bottom: 14px;
  }
  .window-wrap {
    max-width: 960px;
    margin: 0 auto;
  }
  .pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 26px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    padding: 9px 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    box-shadow: var(--elev-1);
  }
  .pill i {
    font-size: 16px;
  }
  .explore {
    text-align: center;
    margin-top: 26px;
  }
  .explore a {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    color: var(--accent);
    transition: gap 0.15s;
  }
  .explore a:hover {
    gap: 13px;
  }
  .explore i {
    font-size: 16px;
  }

  /* voice moment */
  .voice-moment {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(30px, 5vh, 60px) clamp(18px, 4vw, 40px);
    text-align: center;
  }
  .voice-moment i {
    font-size: 48px;
    color: var(--border-strong);
  }
  .voice-moment p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(24px, 3.6vw, 38px);
    line-height: 1.3;
    letter-spacing: -0.4px;
    color: var(--text);
    margin: 14px 0 0;
    text-wrap: balance;
  }

  /* pricing teaser */
  .teaser {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(30px, 4vh, 50px) clamp(18px, 4vw, 40px);
  }
  .teaser .panel {
    background: var(--bg-subtle);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sheet);
    padding: clamp(28px, 5vw, 52px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 26px;
  }
  .teaser .copy {
    flex: 1;
    min-width: 260px;
  }
  .teaser .eyebrow {
    margin-bottom: 10px;
  }
  .teaser h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 3.6vw, 38px);
    line-height: 1.1;
    letter-spacing: -0.6px;
    color: var(--text);
    margin: 0 0 8px;
  }
  .teaser .copy p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
    max-width: 460px;
  }
  .teaser .actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 220px;
  }
  .teaser .primary {
    text-decoration: none;
    text-align: center;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    padding: 15px 28px;
    border-radius: var(--radius-input);
    box-shadow: var(--elev-1);
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .teaser .primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--elev-2);
  }
  .teaser .secondary {
    text-decoration: none;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    color: var(--text-secondary);
    padding: 4px;
  }
  .teaser .secondary:hover {
    color: var(--accent);
  }
</style>
