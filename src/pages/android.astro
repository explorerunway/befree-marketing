---
// Android — founding-tester recruitment landing for the Google Play closed test.
// Mirrors the calm-room system used on pricing.astro / mac.astro.
import Site from '../layouts/Site.astro';

// Tracked link (Brand Studio /l redirect) → the Google Group join page.
// Generic 'android' slug so website joins are attributed separately from social.
const JOIN = 'https://befree-brand-studio.vercel.app/l/android';
const OPTIN = 'https://play.google.com/apps/testing/app.befree';

const perks = [
  { icon: 'ph-bold ph-sparkle', tone: 'plum', title: 'Early access', body: 'The Android build, before it hits the store.' },
  { icon: 'ph-bold ph-star', tone: 'brass', title: '1 year of Pro, free', body: 'Founding testers get a full year on us — no card.' },
  { icon: 'ph-bold ph-chat-teardrop-dots', tone: 'olive', title: 'A direct line to the makers', body: 'Your feedback lands with us and shapes each build.' },
  { icon: 'ph-bold ph-seal-check', tone: 'plum', title: 'Founding badge', body: 'You helped build it — your name in the credits.' },
];

const steps = [
  { n: '1', title: 'Join the tester group', body: 'Tap the button below and hit “Join group.” One tap, no forms.' },
  { n: '2', title: 'Open the opt-in link', body: 'On your Android phone, open the link you’ll get and tap “Become a tester,” then install BeFree.' },
  { n: '3', title: 'Speak your first brain dump', body: 'Say the messy thing out loud — BeFree sorts it into tasks, reminders, groceries and notes.' },
];
---

<Site
  title="BeFree for Android — build it with us"
  description="Join the first Android closed test. Founding testers get a free year of Pro and a direct line to the makers. Limited spots."
  active="android"
>
  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="eyebrow">Android · Closed test</div>
    <h1>Build the Android<br />version with us.</h1>
    <p>
      BeFree is coming to Android — and we’re opening the first closed test to a small founding crew.
      You talk; it sorts your tasks, reminders, groceries and notes.
    </p>
    <div class="cta-row">
      <a href={JOIN} class="btn-solid">Join the closed test</a>
      <span class="cta-meta">Google Play closed test · limited spots</span>
    </div>
  </section>

  <!-- ══════════ PERKS ══════════ -->
  <section class="perks">
    <h2>What founding testers get</h2>
    <div class="grid">
      {
        perks.map((p) => (
          <div class="perk">
            <div class:list={['medallion', p.tone]}><i class={p.icon} /></div>
            <div class="perk-title">{p.title}</div>
            <div class="perk-body">{p.body}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ══════════ HOW TO JOIN ══════════ -->
  <section class="how">
    <h2>How to join</h2>
    <div class="steps">
      {
        steps.map((s) => (
          <div class="step">
            <div class="num">{s.n}</div>
            <div>
              <div class="step-title">{s.title}</div>
              <div class="step-body">{s.body}</div>
            </div>
          </div>
        ))
      }
    </div>
    <p class="fineprint">
      Already joined the group? Open <a href={OPTIN}>the opt-in link</a> on your Android phone to finish.
    </p>
  </section>

  <!-- ══════════ VOICE MOMENT ══════════ -->
  <section class="voice-moment">
    <p>You talk. We ship. The Android build gets your fingerprints on every release.</p>
  </section>

  <!-- ══════════ FINAL CTA ══════════ -->
  <section class="final">
    <div class="panel">
      <div class="grain" aria-hidden="true"></div>
      <div class="inner">
        <div class="mascot"><img src="/assets/cutemic.png" alt="" /></div>
        <h2>Grab a founding seat.</h2>
        <p>A free year of Pro, a direct line to us, and a build you helped shape.</p>
        <a href={JOIN} class="btn-light">Join the closed test</a>
        <div class="meta">Limited spots · Android only</div>
      </div>
    </div>
  </section>
</Site>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--brass-deep);
    margin-bottom: 16px;
  }

  /* hero */
  .hero {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(40px, 7vh, 84px) clamp(18px, 4vw, 40px) clamp(20px, 3vh, 30px);
    text-align: center;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1;
    letter-spacing: -1.6px;
    color: var(--text);
    margin: 0;
    text-wrap: balance;
  }
  .hero p {
    font-family: var(--font-body);
    font-size: clamp(18px, 2.4vw, 22px);
    line-height: 1.5;
    color: var(--text-secondary);
    margin: clamp(16px, 2.5vh, 22px) auto 0;
    max-width: 560px;
    text-wrap: pretty;
  }
  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: clamp(24px, 3.5vh, 34px);
  }
  .btn-solid {
    text-decoration: none;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    padding: 14px 30px;
    border-radius: var(--radius-input);
    box-shadow: var(--elev-1);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-solid:hover {
    transform: translateY(-1px);
    box-shadow: var(--elev-2);
  }
  .cta-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* perks */
  .perks {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(24px, 4vh, 48px) clamp(18px, 4vw, 40px);
  }
  .perks h2,
  .how h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 3.8vw, 38px);
    letter-spacing: -0.6px;
    color: var(--text);
    margin: 0 0 24px;
    text-align: center;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 16px;
  }
  .perk {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    box-shadow: var(--elev-1);
    padding: 24px;
  }
  .medallion {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-medallion);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .medallion i {
    font-size: 20px;
  }
  .medallion.plum {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
  }
  .medallion.brass {
    background: color-mix(in srgb, var(--brass) 20%, transparent);
    color: var(--brass-deep);
  }
  .medallion.olive {
    background: color-mix(in srgb, var(--tool-grocery) 16%, transparent);
    color: var(--tool-grocery);
  }
  .perk-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--text);
    margin-bottom: 5px;
  }
  .perk-body {
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  /* how */
  .how {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(24px, 4vh, 48px) clamp(18px, 4vw, 40px);
  }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    box-shadow: var(--elev-1);
    padding: 20px 22px;
  }
  .num {
    flex: none;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-medallion);
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .step-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    color: var(--text);
    margin-bottom: 3px;
  }
  .step-body {
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .fineprint {
    text-align: center;
    margin-top: 20px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted);
  }
  .fineprint a {
    color: var(--text-secondary);
  }
  .fineprint a:hover {
    color: var(--accent);
  }

  /* voice moment */
  .voice-moment {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(24px, 4vh, 44px) clamp(18px, 4vw, 40px);
    text-align: center;
  }
  .voice-moment p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(22px, 3.2vw, 32px);
    line-height: 1.3;
    letter-spacing: -0.3px;
    color: var(--text);
    margin: 0;
    text-wrap: balance;
  }

  /* final cta */
  .final {
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(20px, 3vh, 40px) clamp(18px, 4vw, 40px) clamp(44px, 7vh, 84px);
  }
  .panel {
    background: var(--bg-inverse);
    border-radius: var(--radius-sheet);
    padding: clamp(36px, 6vw, 72px) clamp(24px, 4vw, 48px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .panel .grain {
    position: absolute;
    inset: 0;
    background-image: url('/assets/paper-grain.png');
    background-size: 256px 256px;
    mix-blend-mode: overlay;
    opacity: 0.18;
    pointer-events: none;
  }
  .panel .inner {
    position: relative;
  }
  .mascot {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    animation: bfBreathe 4200ms cubic-bezier(0.65, 0, 0.35, 1) infinite;
    will-change: transform;
  }
  .mascot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .panel h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 5vw, 52px);
    line-height: 1.02;
    letter-spacing: -1.2px;
    color: #f2ead6;
    margin: 0;
    text-wrap: balance;
  }
  .panel p {
    font-family: var(--font-body);
    font-size: clamp(16px, 2vw, 19px);
    color: #c4b89d;
    margin: 14px auto 26px;
    max-width: 440px;
  }
  .btn-light {
    display: inline-block;
    text-decoration: none;
    background: #f2ead6;
    color: #2a2320;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    padding: 13px 28px;
    border-radius: var(--radius-input);
    transition: transform 0.15s;
  }
  .btn-light:hover {
    transform: translateY(-1px);
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #7e725f;
    margin-top: 18px;
  }
</style>
